{
  "name": "layout-rag-client",
  "version": "1.0.0",
  "description": "Layout RAG Frontend Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:fast": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.layoutrag.client",
    "productName": "Layout RAG Client",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "extraResources": [
      {
        "from": "external_tools/",
        "to": "external_tools/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "**/*",
      "!dist",
      "!*.log",
      "!node_modules/@electron/builder${/*}",
      "!node_modules/electron${/*}"
    ]
  },
  "author": {
    "name": "Dev",
    "email": "dev@example.com"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^24.13.3"
  }
}